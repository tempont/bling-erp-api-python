# ─────────────────────────────────────────────────────────────────────────────
# Exemplo de variáveis para BlingAuthSettings (pydantic-settings, prefixo BLING_)
# ─────────────────────────────────────────────────────────────────────────────
#
# Como usar:
#   cp .env.example .env
#   # edite .env com os valores da sua integração OAuth no portal Bling
#
# Credenciais vêm da aplicação OAuth registrada no Bling e devem bater exatamente
# com redirect_uri configurado lá. O client_secret não deve ser commitado.
#
# Documentação oficial do fluxo: https://developer.bling.com.br/bling-api (# OAuth)
# ─────────────────────────────────────────────────────────────────────────────

# --- Obrigatórias (sem isso BlingAuthSettings falha ao instanciar) ------------

# ID do cliente OAuth (string exibida no cadastro da aplicação na Bling).
BLING_CLIENT_ID=

# Segredo da aplicação (guarde apenas em ambiente seguro / secret manager).
BLING_CLIENT_SECRET=

# URI de redirecionamento registrada na aplicação (ex.: https://seu-dominio.tld/oauth/callback).
# Precisa ser a mesma URL usada ao construir authorize_url / callback da troca por code.
BLING_REDIRECT_URI=

# --- Opcionais (valores default costumam ser os da API de produção) -----------

# Se true (default), o cliente envia cabeçalhos compatíveis com tokens JWT na API v3 (ex.: enable-jwt).
# Aceita valores típicos de bool em string: true/false/1/0.
# BLING_ENABLE_JWT=true

# URL da tela de autorização (default: endpoint oficial Bling v3).
# BLING_AUTHORIZE_URL=https://www.bling.com.br/Api/v3/oauth/authorize

# URL para troca / refresh do token (default: oauth/token oficial).
# BLING_TOKEN_URL=https://www.bling.com.br/Api/v3/oauth/token

# URL para revogação de token quando aplicável.
# BLING_REVOKE_URL=https://www.bling.com.br/Api/v3/oauth/revoke

# Segundos antes do exp do access token para acionar refresh proativo (≥ 0).
# BLING_REFRESH_SKEW_SECONDS=60

# --- Armazenamento de tokens (OAuth salvo por oauth_flow / lido por authenticated_request) ---

# Backend: sqlite (padrão) ou file (JSON).
# BLING_TOKEN_STORE=sqlite

# Caminho opcional do arquivo: .db para sqlite, .json para file.
# Default: ~/.config/bling_jwt_auth/tokens.db ou token.json conforme o backend.
# BLING_TOKEN_STORE_PATH=
